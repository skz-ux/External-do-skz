local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")

local ESPEnabled = false
local ESPObjects = {}
local ComputerESP = {}
local GameStarted = false
local FeraMarked = false

-- PLAYER ESP
local function createPlayerESP(player)
    if ESPObjects[player] then return end
    ESPObjects[player] = {}

    local function setupCharacter(char)
        if ESPObjects[player].Highlight then
            ESPObjects[player].Highlight:Destroy()
        end

        local highlight = Instance.new("Highlight")
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Adornee = char
        highlight.Parent = char

        highlight.FillColor = Color3.fromRGB(0, 255, 0) -- VERDE
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.Enabled = ESPEnabled

        ESPObjects[player].Highlight = highlight
    end

    if player.Character then
        setupCharacter(player.Character)
    end

    player.CharacterAdded:Connect(setupCharacter)
end

-- COMPUTER ESP
local function createComputerESP(computer)
    if ComputerESP[computer] then return end

    local highlight = Instance.new("Highlight")
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = computer
    highlight.Parent = computer

    highlight.FillColor = Color3.fromRGB(0, 100, 255) -- AZUL
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.Enabled = ESPEnabled

    ComputerESP[computer] = { Highlight = highlight }
end

-- TOGGLE ESP
local function setESP(state)
    ESPEnabled = state

    for _, v in pairs(ESPObjects) do
        if v.Highlight then
            v.Highlight.Enabled = state
        end
    end

    for _, v in pairs(ComputerESP) do
        if v.Highlight then
            v.Highlight.Enabled = state
        end
    end
end

-- PLAYERS EXISTENTES
for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        createPlayerESP(p)
    end
end

Players.PlayerAdded:Connect(function(p)
    if p ~= LocalPlayer then
        createPlayerESP(p)
    end
end)

Players.PlayerRemoving:Connect(function(p)
    if ESPObjects[p] and ESPObjects[p].Highlight then
        ESPObjects[p].Highlight:Destroy()
    end
    ESPObjects[p] = nil
end)

-- COMPUTADORES EXISTENTES
for _, obj in pairs(Workspace:GetDescendants()) do
    if obj.Name == "ComputerTable" then
        createComputerESP(obj)
    end
end

Workspace.DescendantAdded:Connect(function(obj)
    if obj.Name == "ComputerTable" then
        createComputerESP(obj)
    end
end)

-- DETECTA INÍCIO DO JOGO + FERA
RunService.RenderStepped:Connect(function()
    if not GameStarted then
        local gv = Workspace:FindFirstChild("GameValues")
        if gv and gv:FindFirstChild("TimeUntilGame") then
            if gv.TimeUntilGame.Value <= 0 then
                GameStarted = true
            end
        end
    end

    if GameStarted and not FeraMarked then
        FeraMarked = true

        task.delay(5, function()
            for player, data in pairs(ESPObjects) do
                local role = player:FindFirstChild("Role")
                if role and role:IsA("StringValue") then
                    if role.Value == "Beast" and data.Highlight then
                        data.Highlight.FillColor = Color3.fromRGB(255, 0, 0)
                    end
                end
            end
        end)
    end
end)

-- GUI BOTÃO INVISÍVEL
local gui = Instance.new("ScreenGui")
gui.Parent = game:GetService("CoreGui")

local btn = Instance.new("TextButton")
btn.Parent = gui
btn.Size = UDim2.new(0, 50, 0, 50)
btn.Position = UDim2.new(0, 10, 0, 10)

-- invisível total
btn.BackgroundTransparency = 1
btn.TextTransparency = 1
btn.BorderSizePixel = 0
btn.AutoButtonColor = false
btn.Text = ""

btn.MouseButton1Click:Connect(function()
    setESP(not ESPEnabled)
end)

-- TECLA F4
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F4 then
        setESP(not ESPEnabled)
    end
end)
